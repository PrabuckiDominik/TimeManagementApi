{
    "compilerOptions": {
        "baseUrl": ".",

        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",

        "strict": true,

        "jsx": "preserve",

        "isolatedModules": true,
        "skipLibCheck": true,

        "resolveJsonModule": true,
        "esModuleInterop": true,

        "forceConsistentCasingInFileNames": true,

        "noEmit": true,

        "allowJs": true,
        "allowSyntheticDefaultImports": true,

        "types": ["vite/client"],

        "paths": {
            "@/*": ["resources/js/*"]
        }
    },

    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts",
        "resources/js/**/*.vue"
    ],

    "exclude": [
        "node_modules",
        "public"
    ]
}
